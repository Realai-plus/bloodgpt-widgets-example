# --- BloodGPT widgets demo ---------------------------------------------------
#
# This example runs in TWO modes, decided by NEXT_PUBLIC_BLOODGPT_API_URL:
#
#  A) MOCK (default, zero credentials): leave NEXT_PUBLIC_BLOODGPT_API_URL empty.
#     The widgets hit this app's built-in mock backend (src/app/api/v1/**) and
#     the server mints a local placeholder token.
#
#  B) REAL backend: set NEXT_PUBLIC_BLOODGPT_API_URL to a live BloodGPT API.
#     The server then exchanges BLOODGPT_API_KEY for a real `wgt_` session
#     token via POST {url}/api/v1/widget-sessions, and the widgets read live
#     data. The real /api/v1/widgets/* endpoints ACCEPT ONLY `wgt_` tokens.

# Your API key. In MOCK mode any value works. In REAL mode this MUST be a valid
# WorkOS API key whose organization exists in the backend, or the mint returns
# 401 invalid_api_key. The browser never sees this — it is used server-side only.
BLOODGPT_API_KEY=demo-secret-key

# The external patient id the session is scoped to.
#  - MOCK mode: use the bundled patient id `patient-jordan-avery`.
#  - REAL mode: must be an external patient id that exists under your org,
#    otherwise the widgets render but show no reports.
DEMO_EXTERNAL_PATIENT_ID=patient-jordan-avery

# Base URL the WIDGETS (browser) call. Empty = same-origin (mock backend).
# Point at a real deployment to use live data, e.g. http://localhost:8000
NEXT_PUBLIC_BLOODGPT_API_URL=

# Optional: base URL the SERVER uses to mint the token, if it differs from the
# browser-facing URL above (e.g. an internal cluster address). Defaults to
# NEXT_PUBLIC_BLOODGPT_API_URL when unset.
# BLOODGPT_API_URL=
