# --- BloodGPT widgets demo ---------------------------------------------------
#
# In production your server holds a long-lived API key and exchanges it for a
# short-lived, patient-scoped *session token* via
#   POST https://backend.bloodgpt.tech/api/v1/widget-sessions
# (see vendor/@bloodgpt/widgets/README.md).
#
# This example ships a MOCK backend (src/app/api/v1/**) so it runs with zero
# real credentials. The key below is only used to demonstrate the
# server-side mint step — any non-empty value works.
BLOODGPT_API_KEY=demo-secret-key

# The external patient id this demo session is scoped to. Matches the mock
# patient defined in src/lib/mock/patients.ts.
DEMO_EXTERNAL_PATIENT_ID=patient-jordan-avery

# Base URL the widgets call. Empty string = same-origin, so the widgets hit
# this app's mock route handlers. Point this at a real deployment to use live
# data instead.
NEXT_PUBLIC_BLOODGPT_API_URL=
